---
const treatments = [
  { t: "Lesiones deportivas", d: "Vuelve a entrenar antes y mejor, con un plan de recuperación guiado paso a paso." },
  { t: "Dolor de espalda y cervical", d: "Terapia manual para aliviar contracturas y corregir lo que las provoca." },
  { t: "Rehabilitación postoperatoria", d: "Recuperación funcional tras cirugía, a tu ritmo y con seguimiento." },
  { t: "Pilates terapéutico", d: "Refuerza tu cuerpo y previene que la lesión vuelva a aparecer." },
];
const method = [
  { t: "Te valoramos", d: "Una primera sesión para entender qué tienes y por qué. Sin diagnósticos vagos." },
  { t: "Plan a tu medida", d: "Tratamiento manual, ejercicio y pautas para casa. Te decimos en cuánto te recuperas." },
  { t: "Vuelves a tu vida", d: "Readaptación progresiva hasta que vuelves a moverte como antes — o mejor." },
];
const facts = [
  { n: "12", l: "años acompañando recuperaciones" },
  { n: "4.000+", l: "sesiones realizadas" },
  { n: "4,9", l: "valoración media (Google)" },
];
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Fisio Vital · Fisioterapia personalizada en Valencia. Lesiones deportivas, dolor de espalda, rehabilitación y pilates terapéutico. Primera valoración sin compromiso." />
    <title>Fisio Vital · Fisioterapia en Valencia</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,500;12..96,600;12..96,700&family=Hanken+Grotesk:wght@400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body>
    <header class="bar">
      <a href="#top" class="brand">Fisio<span>Vital</span></a>
      <nav class="bar-nav">
        <a href="#tratamientos">Tratamientos</a>
        <a href="#metodo">Cómo trabajamos</a>
        <a href="#cita">Pedir cita</a>
      </nav>
      <a href="#cita" class="btn btn-sm">Pedir cita</a>
    </header>

    <main id="top">
      <!-- HERO -->
      <section class="hero">
        <div class="hero-copy">
          <p class="eyebrow"><span class="dot"></span>Fisioterapia · Valencia</p>
          <h1>Vuelve a moverte <em>como antes.</em></h1>
          <p class="lead">Fisioterapia personalizada con fisioterapeutas colegiados. En la primera valoración te explicamos qué tienes y en cuánto tiempo te recuperas — sin compromiso.</p>
          <div class="hero-cta">
            <a href="#cita" class="btn">Pedir primera valoración</a>
            <a href="tel:+34960000000" class="link-soft">o llámanos: 960 00 00 00</a>
          </div>
        </div>

        <!-- Firma: goniómetro animado (rango de movimiento) -->
        <figure class="gonio" aria-label="Recuperación del rango de movimiento">
          <svg viewBox="0 0 320 230">
            <g fill="none" stroke="currentColor">
              <path d="M40 200 A 130 130 0 0 1 280 200" stroke-width="1.5" opacity=".35"/>
              <line x1="40" y1="200" x2="280" y2="200" stroke-width="1.5" opacity=".35"/>
            </g>
            <g stroke="currentColor" stroke-width="1.5" opacity=".5">
              <line x1="40" y1="200" x2="52" y2="200"/>
              <line x1="63" y1="133" x2="74" y2="139"/>
              <line x1="118" y1="86" x2="125" y2="96"/>
              <line x1="160" y1="70" x2="160" y2="82"/>
              <line x1="202" y1="86" x2="195" y2="96"/>
              <line x1="257" y1="133" x2="246" y2="139"/>
              <line x1="268" y1="200" x2="280" y2="200"/>
            </g>
            <line class="needle" x1="160" y1="200" x2="160" y2="80" stroke-width="3.5" stroke-linecap="round"/>
            <circle cx="160" cy="200" r="7" class="pivot"/>
          </svg>
          <figcaption><strong>+ rango de movimiento</strong>devolvemos la movilidad que el dolor te quitó</figcaption>
        </figure>
      </section>

      <!-- Confianza -->
      <section class="trust">
        {facts.map((f) => (
          <div class="fact">
            <span class="fact-n">{f.n}</span>
            <span class="fact-l">{f.l}</span>
          </div>
        ))}
        <p class="trust-note">Colegiados nº 1842 · Fisioterapia deportiva y clínica</p>
      </section>

      <!-- Tratamientos -->
      <section id="tratamientos" class="treat">
        <header class="sec-head">
          <p class="eyebrow"><span class="dot"></span>En qué te ayudamos</p>
          <h2>Si te limita, lo tratamos.</h2>
        </header>
        <div class="treat-grid">
          {treatments.map((t) => (
            <article class="card" data-reveal>
              <span class="card-mark" aria-hidden="true"></span>
              <h3>{t.t}</h3>
              <p>{t.d}</p>
            </article>
          ))}
        </div>
      </section>

      <!-- Método -->
      <section id="metodo" class="method">
        <header class="sec-head light">
          <p class="eyebrow"><span class="dot"></span>Cómo trabajamos</p>
          <h2>De la primera visita<br/>a volver a tu vida.</h2>
        </header>
        <ol class="steps">
          {method.map((s, i) => (
            <li class="step" data-reveal>
              <span class="step-num">{String(i + 1).padStart(2, "0")}</span>
              <h3>{s.t}</h3>
              <p>{s.d}</p>
            </li>
          ))}
        </ol>
      </section>

      <!-- Resultado destacado -->
      <section class="result" data-reveal>
        <p class="result-stat"><span>92%</span> de nuestros pacientes nota mejoría en las <em>3 primeras sesiones.</em></p>
        <p class="result-sub">No prometemos milagros. Prometemos un plan claro y a alguien que te escucha.</p>
      </section>

      <!-- Testimonio -->
      <section class="quote">
        <blockquote data-reveal>
          <p>“Llevaba meses con el hombro fastidiado y arrastrándolo. En un mes volví a entrenar. Me explicaron <em>todo</em> en cada paso.”</p>
          <cite>— Laura M., corredora</cite>
        </blockquote>
      </section>

      <!-- Cita -->
      <section id="cita" class="book">
        <div class="book-info">
          <p class="eyebrow"><span class="dot"></span>Pide tu cita</p>
          <h2>Empieza tu<br/>recuperación hoy.</h2>
          <dl class="contact">
            <div><dt>Dónde</dt><dd>Av. de la Salud 45<br/>46010 Valencia</dd></div>
            <div><dt>Horario</dt><dd>Lun–Vie · 08:00 – 20:00</dd></div>
            <div><dt>Teléfono</dt><dd>960 00 00 00 · WhatsApp</dd></div>
          </dl>
        </div>
        <form class="book-form" action="https://api.web3forms.com/submit" method="POST">
          <input type="hidden" name="access_key" value="TU-ACCESS-KEY-WEB3FORMS" />
          <input type="hidden" name="subject" value="Nueva valoración — Fisio Vital" />
          <input type="checkbox" name="botcheck" style="display:none" tabindex="-1" />
          <h3>Reserva tu primera valoración</h3>
          <label>Nombre<input name="name" required autocomplete="name" /></label>
          <label>Teléfono<input name="phone" required autocomplete="tel" inputmode="tel" /></label>
          <label>¿Qué te pasa?
            <select name="motivo">
              <option>Lesión deportiva</option>
              <option>Dolor de espalda o cervical</option>
              <option>Rehabilitación postoperatoria</option>
              <option>Pilates terapéutico</option>
              <option>Otro / no estoy seguro</option>
            </select>
          </label>
          <button type="submit" class="btn btn-block">Pedir valoración</button>
          <p class="form-note">Te llamamos para confirmar en menos de 24 h. Sin compromiso.</p>
        </form>
      </section>
    </main>

    <footer class="foot">
      <span class="brand sm">Fisio<span>Vital</span></span>
      <p>Fisioterapia personalizada · Valencia</p>
      <div class="foot-links"><a href="#">Instagram</a><a href="#">Aviso legal</a></div>
    </footer>

    <script>
      const io = new IntersectionObserver((es) => {
        for (const e of es) if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
      }, { threshold: 0.18 });
      document.querySelectorAll('[data-reveal]').forEach((el) => io.observe(el));
    </script>
  </body>
</html>

<style is:global>
  :root {
    --bg: #f3f5f3;
    --paper: #ffffff;
    --mint: #e7efe9;
    --ink: #14241f;
    --pine: #1f4a3d;
    --pine-deep: #163a30;
    --sage: #6f8b80;
    --vital: #e0603f;
    --line: #d8e0db;
    --display: "Bricolage Grotesque", system-ui, sans-serif;
    --ui: "Hanken Grotesk", system-ui, sans-serif;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body {
    background: var(--bg); color: var(--ink);
    font-family: var(--ui); font-size: 17px; line-height: 1.6;
    -webkit-font-smoothing: antialiased; overflow-x: hidden;
  }
  ::selection { background: var(--vital); color: #fff; }
  a { color: inherit; text-decoration: none; }
  em { font-style: normal; color: var(--vital); }

  .eyebrow {
    display: inline-flex; align-items: center; gap: 9px;
    font-size: 13px; letter-spacing: .14em; text-transform: uppercase;
    color: var(--pine); font-weight: 600; margin-bottom: 22px;
  }
  .eyebrow .dot { width: 7px; height: 7px; border-radius: 50%; background: var(--vital); }

  .btn {
    display: inline-block; font-family: var(--ui); font-weight: 600; font-size: 16px;
    padding: 15px 28px; border-radius: 100px; background: var(--pine); color: #fff;
    border: 1px solid var(--pine); transition: transform .2s, background .25s, box-shadow .25s;
  }
  .btn:hover { background: var(--pine-deep); transform: translateY(-2px); box-shadow: 0 14px 30px -14px rgba(31,74,61,.7); }
  .btn-sm { padding: 11px 20px; font-size: 15px; }
  .btn-block { width: 100%; padding: 16px; }
  .link-soft { color: var(--sage); font-weight: 500; }
  .link-soft:hover { color: var(--pine); }

  /* Bar */
  .bar {
    position: sticky; top: 0; z-index: 30;
    display: flex; align-items: center; justify-content: space-between;
    padding: 18px clamp(24px, 6vw, 80px);
    background: color-mix(in srgb, var(--bg) 85%, transparent); backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--line);
  }
  .brand { font-family: var(--display); font-weight: 700; font-size: 24px; letter-spacing: -.02em; color: var(--ink); }
  .brand span { color: var(--vital); }
  .brand.sm { font-size: 21px; }
  .bar-nav { display: flex; gap: 32px; font-size: 15px; }
  .bar-nav a { color: var(--sage); transition: color .25s; }
  .bar-nav a:hover { color: var(--ink); }

  /* HERO */
  .hero {
    display: grid; grid-template-columns: 1.1fr .9fr; gap: clamp(30px, 5vw, 64px);
    align-items: center; padding: clamp(48px, 7vw, 96px) clamp(24px, 6vw, 80px) clamp(40px, 5vw, 64px);
  }
  .hero h1 {
    font-family: var(--display); font-weight: 600;
    font-size: clamp(42px, 7vw, 82px); line-height: 1.0; letter-spacing: -.03em; margin-bottom: 26px;
  }
  .lead { max-width: 44ch; color: #45554e; font-size: clamp(16px, 1.5vw, 19px); }
  .hero-cta { display: flex; align-items: center; gap: 26px; margin-top: 36px; flex-wrap: wrap; }
  .hero-copy { animation: rise .9s cubic-bezier(.2,.7,.2,1) both; }
  @keyframes rise { from { opacity: 0; transform: translateY(24px); } }

  /* Goniómetro */
  .gonio {
    background: var(--paper); border: 1px solid var(--line); border-radius: 20px;
    padding: clamp(28px, 4vw, 48px); color: var(--pine);
    box-shadow: 0 30px 60px -40px rgba(20,36,31,.4); animation: rise 1.1s .15s cubic-bezier(.2,.7,.2,1) both;
  }
  .gonio svg { width: 100%; height: auto; display: block; }
  .needle { stroke: var(--vital); transform-origin: 160px 200px; animation: sweep 4.5s cubic-bezier(.5,0,.2,1) infinite; }
  .pivot { fill: var(--vital); }
  @keyframes sweep {
    0%   { transform: rotate(-58deg); }
    45%  { transform: rotate(20deg); }
    55%  { transform: rotate(20deg); }
    100% { transform: rotate(-58deg); }
  }
  .gonio figcaption { margin-top: 24px; color: var(--sage); font-size: 14.5px; line-height: 1.45; }
  .gonio figcaption strong { display: block; color: var(--ink); font-family: var(--display); font-weight: 600; font-size: 19px; margin-bottom: 4px; }

  /* Trust */
  .trust {
    display: flex; flex-wrap: wrap; align-items: center; gap: clamp(24px, 5vw, 64px);
    padding: 30px clamp(24px, 6vw, 80px); border-top: 1px solid var(--line); border-bottom: 1px solid var(--line);
    background: var(--mint);
  }
  .fact { display: flex; flex-direction: column; }
  .fact-n { font-family: var(--display); font-weight: 700; font-size: clamp(28px, 3.4vw, 40px); color: var(--pine); line-height: 1; }
  .fact-l { font-size: 13.5px; color: var(--sage); margin-top: 6px; max-width: 18ch; }
  .trust-note { margin-left: auto; font-size: 14px; color: var(--sage); }

  /* Secciones */
  section { padding-left: clamp(24px, 6vw, 80px); padding-right: clamp(24px, 6vw, 80px); }
  .treat, .method, .result, .quote, .book { padding-top: clamp(64px, 9vw, 120px); padding-bottom: clamp(64px, 9vw, 120px); }
  .sec-head { margin-bottom: 54px; max-width: 640px; }
  .sec-head h2 {
    font-family: var(--display); font-weight: 600;
    font-size: clamp(32px, 4.6vw, 56px); line-height: 1.04; letter-spacing: -.025em;
  }
  [data-reveal] { opacity: 0; transform: translateY(22px); transition: opacity .7s ease, transform .7s ease; }
  [data-reveal].in { opacity: 1; transform: none; }

  /* Tratamientos */
  .treat-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; }
  .card {
    background: var(--paper); border: 1px solid var(--line); border-radius: 18px;
    padding: clamp(26px, 3vw, 40px); transition: transform .25s, box-shadow .25s, border-color .25s;
  }
  .card:hover { transform: translateY(-4px); box-shadow: 0 24px 50px -34px rgba(20,36,31,.45); border-color: var(--sage); }
  .card-mark { display: block; width: 34px; height: 4px; border-radius: 4px; background: var(--vital); margin-bottom: 22px; }
  .card h3 { font-family: var(--display); font-weight: 600; font-size: clamp(21px, 2.4vw, 26px); margin-bottom: 12px; letter-spacing: -.01em; }
  .card p { color: #56655e; }

  /* Método (banda pino) */
  .method { background: var(--pine-deep); border-radius: 28px; margin-left: clamp(12px, 3vw, 40px); margin-right: clamp(12px, 3vw, 40px); }
  .sec-head.light h2 { color: #fff; }
  .sec-head.light .eyebrow { color: #9cc3b4; }
  .steps { list-style: none; display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(22px, 3vw, 48px); }
  .step { border-top: 1px solid rgba(255,255,255,.18); padding-top: 24px; }
  .step-num { font-family: var(--display); font-weight: 700; font-size: 15px; color: var(--vital); display: block; margin-bottom: 16px; letter-spacing: .08em; }
  .step h3 { font-family: var(--display); font-weight: 600; font-size: 24px; margin-bottom: 11px; color: #fff; }
  .step p { color: #adc7bd; }

  /* Resultado */
  .result { text-align: center; max-width: 920px; margin: 0 auto; }
  .result-stat { font-family: var(--display); font-weight: 600; font-size: clamp(28px, 4.4vw, 50px); line-height: 1.12; letter-spacing: -.02em; }
  .result-stat span { color: var(--pine); }
  .result-sub { margin-top: 22px; color: var(--sage); font-size: clamp(16px, 1.6vw, 19px); }

  /* Testimonio */
  .quote { background: var(--mint); text-align: center; }
  .quote blockquote { max-width: 860px; margin: 0 auto; }
  .quote p { font-family: var(--display); font-weight: 500; font-size: clamp(24px, 3.6vw, 40px); line-height: 1.22; letter-spacing: -.015em; }
  .quote cite { display: block; margin-top: 26px; font-style: normal; font-size: 14px; letter-spacing: .1em; text-transform: uppercase; color: var(--sage); }

  /* Cita */
  .book { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(34px, 6vw, 84px); align-items: center; }
  .book h2 { font-family: var(--display); font-weight: 600; font-size: clamp(30px, 4.2vw, 52px); line-height: 1.04; letter-spacing: -.025em; }
  .contact { margin-top: 40px; display: grid; gap: 22px; }
  .contact dt { font-size: 13px; letter-spacing: .12em; text-transform: uppercase; color: var(--vital); font-weight: 600; margin-bottom: 6px; }
  .contact dd { color: var(--ink); line-height: 1.5; }
  .book-form { background: var(--paper); border: 1px solid var(--line); border-radius: 22px; padding: clamp(26px, 3vw, 40px); box-shadow: 0 30px 70px -44px rgba(20,36,31,.4); }
  .book-form h3 { font-family: var(--display); font-weight: 600; font-size: 25px; margin-bottom: 24px; letter-spacing: -.01em; }
  .book-form label { display: block; font-size: 13px; letter-spacing: .04em; text-transform: uppercase; color: var(--sage); font-weight: 600; margin-bottom: 18px; }
  .book-form input, .book-form select {
    width: 100%; margin-top: 8px; padding: 13px 14px; background: var(--bg);
    border: 1px solid var(--line); border-radius: 10px; color: var(--ink);
    font-family: var(--ui); font-size: 16px; text-transform: none; letter-spacing: normal; font-weight: 400;
    transition: border-color .25s, background .25s;
  }
  .book-form input:focus, .book-form select:focus { outline: none; border-color: var(--pine); background: var(--paper); }
  .form-note { text-align: center; font-size: 13.5px; color: var(--sage); margin-top: 16px; text-transform: none; letter-spacing: normal; font-weight: 400; }

  /* Footer */
  .foot {
    display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 16px;
    padding: 32px clamp(24px, 6vw, 80px); border-top: 1px solid var(--line);
  }
  .foot p { color: var(--sage); font-size: 14px; }
  .foot-links { display: flex; gap: 22px; font-size: 14px; }
  .foot-links a { color: var(--sage); transition: color .25s; }
  .foot-links a:hover { color: var(--pine); }

  @media (max-width: 860px) {
    .bar-nav { display: none; }
    .hero { grid-template-columns: 1fr; }
    .gonio { max-width: 420px; }
    .treat-grid { grid-template-columns: 1fr; }
    .steps { grid-template-columns: 1fr; }
    .trust-note { margin-left: 0; width: 100%; }
    .book { grid-template-columns: 1fr; }
  }
  @media (prefers-reduced-motion: reduce) {
    *, [data-reveal] { animation: none !important; transition: none !important; opacity: 1 !important; transform: none !important; }
    .needle { transform: rotate(20deg); }
  }
</style>
