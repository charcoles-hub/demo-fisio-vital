---
import { site } from '../config/site';
---
<section id="pricing" class="bg-surface-2 py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-5">
    <h2 data-reveal class="text-center text-3xl font-extrabold tracking-tight text-ink sm:text-4xl">
      {site.pricingTitle}
    </h2>
    <div class="mt-14 grid gap-6 md:grid-cols-3">
      {site.pricing.map((p) => (
        <div data-reveal class={`flex flex-col rounded-2xl border p-8 ${p.highlight ? 'border-brand-500 bg-elevated shadow-xl ring-2 ring-brand-500/20 md:-translate-y-3' : 'border-line bg-elevated shadow-sm'}`}>
          {p.highlight && (
            <span class="mb-3 inline-block self-start rounded-full bg-brand-600 px-3 py-1 text-xs font-bold uppercase tracking-wide text-white">Recomendado</span>
          )}
          <h3 class="text-lg font-bold text-ink">{p.name}</h3>
          <div class="mt-3 flex items-baseline gap-1">
            <span class="text-4xl font-extrabold text-ink">{p.price}</span>
            <span class="text-sm text-muted">{p.period}</span>
          </div>
          <ul class="mt-6 flex-1 space-y-3 text-sm text-muted">
            {p.features.map((feat) => (
              <li class="flex items-start gap-2">
                <svg class="mt-0.5 h-5 w-5 flex-none text-brand-600" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                <span>{feat}</span>
              </li>
            ))}
          </ul>
          <a href="#contacto"
             class={`mt-8 rounded-full px-6 py-3 text-center font-semibold transition ${p.highlight ? 'bg-brand-600 text-white hover:bg-brand-700' : 'border border-line text-ink hover:border-brand-400 hover:text-brand-500'}`}>
            {p.cta}
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
